#!/bin/sh
# Xsetup - run as root before the login dialog appears

xrandr --setprovideroutputsource "AMD Radeon Graphics @ pci:0000:06:00.0" NVIDIA-0 
xrandr --dpi 75

monitor_list=($(xrandr | grep " connected" | awk '{print $1}'))
monitor_count=${#monitor_list[@]}

# The monitor sequence
# DP-0 // Type C
# HDMI-0
# DP-3
# eDP-1-0

case "$monitor_count" in
    2)
        xrandr --output "${monitor_list[0]}" --mode 1920x1080 --primary
        xrandr --output "${monitor_list[1]}" --same-as "${monitor_list[0]}" --mode 1920x1080
        ;;
    3)
        xrandr --output "${monitor_list[0]}" --left-of "${monitor_list[2]}" --mode 1920x1080
        xrandr --output "${monitor_list[1]}" --right-of "${monitor_list[2]}" --mode 1920x1080
        xrandr --output "${monitor_list[2]}" --mode 1920x1080 --primary
        ;;
    4)
        xrandr --output "${monitor_list[0]}" --mode 2560x1440 --primary
        xrandr --output "${monitor_list[1]}" --left-of "${monitor_list[0]}" --mode 1920x1080
        xrandr --output "${monitor_list[2]}" --right-of "${monitor_list[0]}" --mode 1920x1080
        xrandr --output "${monitor_list[3]}" --same-as "${monitor_list[0]}" --mode 1920x1080
        ;;
    *)
        xrandr --output eDP-1-0 --mode 1920x1080 --primary  
        ;;
esac

# xrandr --output eDP-1-0 --off
# xrandr --output DP-0 --mode 2560x1440 --primary
# xrandr --output DP-3 --right-of DP-0 --mode 1920x1080
# xrandr --output HDMI-0 --left-of DP-0 --mode 1920x1080
# xrandr --output eDP-1-0 --same-as HDMI-0 --mode 1920x1080
