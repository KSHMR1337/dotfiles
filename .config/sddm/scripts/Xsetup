#!/bin/sh
# Xsetup - run as root before the login dialog appears

xrandr --setprovideroutputsource "AMD Radeon Graphics @ pci:0000:06:00.0" NVIDIA-0 
xrandr --dpi 75

monitor_count=$(xrandr | grep -c " connected ")
monitor_list=($(xrandr | grep " connected" | awk '{print $1}'))

for ((i = 1; i <= $#monitor_list; i++)); do
	declare "monitor_$i=${monitor_list[$i]}"
	# echo ${monitor_list[$i]}
done

# The monitor sequence
# DP-0 // Type C
# HDMI-0
# DP-3
# eDP-1-0



case "$monitor_count" in
    2)
	xrandr --output $monitor_1 --mode 1920x1080 --primary
	xrandr --output $monitor_2 --off
        ;;
    3)
	xrandr --output $monitor_1 --left-of $monitor_3 --mode 1920x1080
	xrandr --output $monitor_2 --right-of $monitor_3 --mode 1920x1080
	xrandr --output $monitor_3 --mode 1920x1080 --primary
        ;;
    4)
	xrandr --output $monitor_1 --mode 2560x1440 --primary
	xrandr --output $monitor_2 --left-of $monitor_1 --mode 1920x1080
	xrandr --output $monitor_3 --right-of $monitor_1 --mode 1920x1080
	xrandr --output $monitor_4 --off  
        ;;
    *)
	xrandr --output eDP-1-0 --mode 1920x1080 --primary  
        ;;
esac

# xrandr --output eDP-1-0 --off
# xrandr --output DP-0 --mode 2560x1440 --primary
# xrandr --output DP-3 --right-of DP-0 --mode 1920x1080
# xrandr --output HDMI-0 --left-of DP-0 --mode 1920x1080
